<launch>
  <arg name="world_file" default="$(find-pkg-share antonie_gazebo)/worlds/empty.sdf"/>
  <arg name="bridge_config" default="$(find-pkg-share antonie_gazebo)/config/gz_bridge.yaml"/>

  <set_env name="GZ_SIM_RESOURCE_PATH" 
           value="$(find-pkg-share wut_gazebo_models)/models:$(env GZ_SIM_RESOURCE_PATH '')" />

  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-s -r $(var world_file)"/>
    <arg name="on_exit_shutdown" value="True"/>
  </include>

  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-g --render-engine ogre"/>
    <arg name="on_exit_shutdown" value="True"/>
  </include>

  <node name="ros_gz_bridge" pkg="ros_gz_bridge" exec="parameter_bridge" output="screen">
    <param name="config_file" value="$(var bridge_config)"/>
  </node>
</launch>
